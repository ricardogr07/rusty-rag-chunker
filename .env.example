# Copy to .env and fill in your values.

# OpenAI API key — required for the ask command and OpenAI embeddings (text-embedding-3-small).
# Without this key, the local sentence-transformers model is used and ask is unavailable.
OPENAI_API_KEY=sk-proj-your-key-here

# Qdrant collection name (default: rusty_rag_chunks).
# The real-corpus demo uses rusty_rag_corpus.
QDRANT_COLLECTION=rusty_rag_corpus

# Minimum cosine similarity for the ask command (default: 0.50).
# Queries whose top retrieved chunk scores below this are blocked without an LLM call.
# Recommended range: 0.40–0.65. Off-topic queries typically score below 0.20.
RETRIEVAL_MIN_SCORE=0.40

# Qdrant server address (defaults shown — uncomment to override).
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
